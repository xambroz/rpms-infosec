From 16cfccc71a0d3bdd072275460f1e62aaa619f367 Mon Sep 17 00:00:00 2001
From: Arnaud Rebillout <arnaudr@debian.org>
Date: Fri, 21 Nov 2025 10:57:44 +0700
Subject: [PATCH 05/10] Don't ignore compile errors for xhydra and pw-inspector

This is something that distributions (at least Debian) has to patch,
because we want to be notified if something fails to build, we don't
want that a part of the package fails to build silently.

Looking at pw-inspector, it's a small C programm with no dependency, so
why would it fail to build anyway?

xhydra build is already conditioned by XHYDRA_SUPPORT: users who don't
want it can just build in a environment without GTK, if ever for some
reason it fails to build.
---
 Makefile.am | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/Makefile.am b/Makefile.am
index 52968e3e..a9403449 100644
--- a/Makefile.am
+++ b/Makefile.am
@@ -59,10 +59,10 @@ hydra:	hydra.c $(OBJ)
 	@echo
 
 xhydra:	
-	-cd hydra-gtk && sh ./make_xhydra.sh
+	cd hydra-gtk && sh ./make_xhydra.sh
 
 pw-inspector: pw-inspector.c
-	-$(CC) $(OPTS) $(SEC) $(CFLAGS) $(CPPFLAGS) $(LDFLAGS) -o pw-inspector $(PWI_LOGO) pw-inspector.c
+	$(CC) $(OPTS) $(SEC) $(CFLAGS) $(CPPFLAGS) $(LDFLAGS) -o pw-inspector $(PWI_LOGO) pw-inspector.c
 
 .c.o:	
 	$(CC) $(OPTS) $(SEC) $(CFLAGS) $(CPPFLAGS) -c $< $(XDEFINES) $(XIPATHS)

From 1174cf490c6064e3860c7a58d95f50c7a989a134 Mon Sep 17 00:00:00 2001
From: Arnaud Rebillout <arnaudr@debian.org>
Date: Fri, 21 Nov 2025 11:06:01 +0700
Subject: [PATCH 06/10] hydra-gtk: Reduce make_hydra.sh to the minimum

Following the logic of the last commit: no need to let it fail silently
or to wrap commands, hide output, etc etc... Just run the standard
commands, that's it.
---
 hydra-gtk/make_xhydra.sh | 25 +++++++------------------
 1 file changed, 7 insertions(+), 18 deletions(-)

diff --git a/hydra-gtk/make_xhydra.sh b/hydra-gtk/make_xhydra.sh
index 04f4a3a3..33a74791 100755
--- a/hydra-gtk/make_xhydra.sh
+++ b/hydra-gtk/make_xhydra.sh
@@ -1,20 +1,9 @@
-#!/bin/bash
-PKG_CONFIG_PATH=$PKG_CONFIG_PATH:/opt/gnome/lib/pkgconfig
-export PKG_CONFIG_PATH
-echo "Trying to compile xhydra now (hydra gtk gui) - don't worry if this fails, this is really optional ..."
-./configure > /dev/null 2> errors
-test -e Makefile || {
-  echo "Error: configure wasnt happy. Analyse this:"
-  cat errors
-  exit 1
-}
-make > /dev/null 2> errors
-test -e src/xhydra || {
-  echo "Error: could not compile. Analyse this:"
-  cat errors
-  echo
-  echo 'Do not worry, as I said, xhydra is really optional. ./hydra is ready to go!'
-  exit 0
-}
+#!/bin/sh
+
+set -e
+
+echo "Trying to compile xhydra now (hydra gtk gui)"
+./configure
+make
 cp -v src/xhydra ..
 echo "The GTK GUI is ready, type \"./xhydra\" to start"

