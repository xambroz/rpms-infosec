From 0b8de66de5fb8e9867403c8f94058257085141a4 Mon Sep 17 00:00:00 2001
From: Arnaud Rebillout <arnaudr@debian.org>
Date: Fri, 21 Nov 2025 11:17:47 +0700
Subject: [PATCH 02/10] hydra-gtk: Add -Wno-deprecated-declarations

---
 hydra-gtk/src/Makefile.am | 4 ++++
 1 file changed, 4 insertions(+)

diff --git a/hydra-gtk/src/Makefile.am b/hydra-gtk/src/Makefile.am
index 03984ce4..814c422e 100644
--- a/hydra-gtk/src/Makefile.am
+++ b/hydra-gtk/src/Makefile.am
@@ -1,6 +1,10 @@
 ## Process this file with automake to produce Makefile.in
 
+# Note: Use no-deprecated-declarations until someone finishes the Gtk3 port,
+# ie. move from GtkTable to GtkGrid, and a few other details.
+
 INCLUDES = \
+	-Wno-deprecated-declarations \
 	-DPACKAGE_DATA_DIR=\""$(datadir)"\" \
 	-DPACKAGE_LOCALE_DIR=\""$(prefix)/$(DATADIRNAME)/locale"\" \
 	@PACKAGE_CFLAGS@

From b60fbf164e8a7650100d1fd5cccd7e6fc14a7137 Mon Sep 17 00:00:00 2001
